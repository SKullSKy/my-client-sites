  // Add event listener to the cart icon
document.querySelector('.cart-icon').addEventListener('click', () => {
    // Get the cart element
    const cart = document.getElementById('cart');

    // If cart is not null, scroll to it
    if (cart) {
        cart.scrollIntoView({ behavior: 'smooth' });
    }
});

// Function to handle adding to cart
function addToCart(event) {
    // Get the product card
    const productCard = event.target.closest('.product-card');

    // Get the product name and price
    const productName = productCard.querySelector('h3').textContent;
    const productPrice = productCard.querySelector('.price').textContent;

    // Create a cart item object
    const cartItem = {
        name: productName,
        price: productPrice,
    };

    // Add the cart item to local storage
    const cartItems = JSON.parse(localStorage.getItem('cartItems')) || [];
    cartItems.push(cartItem);
    localStorage.setItem('cartItems', JSON.stringify(cartItems));

    // Display a success message
    alert(`Added ${productName} to cart!`);
}

// Get all add to cart buttons
const addToFileCartButtons = document.querySelectorAll('.product-card button');

// Add event listener to each button
addToFileCartButtons.forEach(button => {
    button.addEventListener('click', addToCart);
});

// Function to handle newsletter subscription
function subscribeToNewsletter(event) {
    event.preventDefault();

    // Get the email input
    const emailInput = document.querySelector('input[type="email"]');

    // Get the email value
    const email = emailInput.value;

    // Check if the email is valid
    if (!email || !email.includes('@')) {
        alert('Please enter a valid email address!');
        return;
    }

    // Add the email to local storage
    const subscribers = JSON.parse(localStorage.getItem('subscribers')) || [];
    subscribers.push(email);
    localStorage.setItem('subscribers', JSON.stringify(subscribers));

    // Display a success message
    alert(`Thank you for subscribing to our newsletter, ${email}!`);
}

// Get the newsletter form
const newsletterForm = document.querySelector('.newsletter form');

// Add event listener to the form
newsletterForm.addEventListener('submit', subscribeToNewsletter);

// Function to handle scrolling to sections
function scrollToSection(event) {
    event.preventDefault();

    // Get the section ID
    const sectionId = event.target.getAttribute('href');

    // Get the section element
    const section = document.querySelector(sectionId);

    // If section is not null, scroll to it
    if (section) {
        section.scrollIntoView({ behavior: 'smooth' });
    }
}

// Get all nav links
const navLinks = document.querySelectorAll('nav a');

// Add event listener to each link
navLinks.forEach(link => {
    link.addEventListener('click', scrollToSection);
});
